-- ==================== VÒNG LẶP BYPASS CHẨN ĐOÁN ====================
local function remoteTrigger(prompt)
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp and prompt.Parent:IsA("BasePart") then
            local oldCFrame = hrp.CFrame
            hrp.CFrame = prompt.Parent.CFrame
            task.wait(0.1); prompt:InputHoldBegin(); task.wait(0.1); prompt:InputHoldEnd(); hrp.CFrame = oldCFrame
        end
    end
end

task.spawn(function()
    while task.wait(1) do
        -- Lấy bệnh nhân
        local patient = nil
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and (v:FindFirstChild("Humanoid") or v.Name:lower():find("patient") or v.Name:lower():find("npc") or v.Name:lower():find("animal") or v.Name:lower():find("pet")) then
                if v.Name:lower():find(LocalPlayer.Name:lower()) or (v:FindFirstChild("Owner") and v.Owner.Value == LocalPlayer) or v:GetAttribute("Owner") == LocalPlayer.UserId or v:GetAttribute("Owner") == LocalPlayer.Name then
                    patient = v; break
                end
            end
        end
        
        -- Cập nhật bảng và lấy thuốc
        if patient then
            local pName = patient.Name:gsub(LocalPlayer.Name, ""):gsub("'s", "")
            if pName == "" or #pName < 2 then pName = "Thú cưng" end
            
            local medicine = patient:GetAttribute("Medicine") or patient:GetAttribute("RequiredMedicine")
            if not medicine then
                local mVal = patient:FindFirstChild("Medicine") or patient:FindFirstChild("RequiredMedicine")
                if mVal then medicine = mVal.Value end
            end
            
            if not medicine then
                for _, bg in pairs(patient:GetDescendants()) do
                    if bg:IsA("TextLabel") and (bg.Text:find(":") or bg.Text:lower():find("cần")) then
                        medicine = bg.Text:split(":")[2] and bg.Text:split(":")[2]:gsub(" ", "") or bg.Text
                    end
                end
            end
            
            if medicine and medicine ~= "" then
                InfoLbl.Text = "Bệnh nhân: " .. pName .. "\n💊 Thuốc: " .. tostring(medicine)
                if BypassEnabled and LocalPlayer.Character then
                    if not (LocalPlayer.Character:FindFirstChild(medicine) or LocalPlayer.Backpack:FindFirstChild(medicine)) then
                        for _, prompt in pairs(workspace:GetDescendants()) do
                            if prompt:IsA("ProximityPrompt") and (prompt.Parent.Name:lower():find(medicine:lower()) or prompt.ActionText:lower():find(medicine:lower())) then
                                remoteTrigger(prompt); task.wait(0.5); break
                            end
                        end
                    end
                end
            else
                InfoLbl.Text = "Bệnh nhân: " .. pName .. "\n🔍 Đang chẩn đoán..."
            end
        else
            InfoLbl.Text = "❌ Chưa có bệnh nhân!"
        end
        
        -- Bypass Máy phân tích & Máy tính
        if BypassEnabled and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
            if tool then
                local tName = tool.Name:lower()
                if tName:find("dna") or tName:find("sample") or tName:find("mẫu") then
                    for _, prompt in pairs(workspace:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") and (prompt.Parent.Name:lower():find("analyzer") or prompt.ActionText:lower():find("analyze")) then
                            remoteTrigger(prompt); break
                        end
                    end
                elseif tName:find("analyzed") or tName:find("result") or tName:find("kết quả") then
                    for _, prompt in pairs(workspace:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") and (prompt.Parent.Name:lower():find("computer") or prompt.ActionText:lower():find("diagnose")) then
                            remoteTrigger(prompt); break
                        end
                    end
                end
            end
        end
    end
end)
