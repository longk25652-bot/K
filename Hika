-- TÍNH NĂNG 1: Instant Interact NPC (Bypass 0s)
local InstantEnabled = false
local ProximityConnection

local function HackProximity(prompt)
    if prompt:IsA("ProximityPrompt") then
        prompt.HoldDuration = 0
        if InstantEnabled then
            prompt.PromptButtonHoldBegan:Connect(function()
                fireproximityprompt(prompt)
            end)
        end
    end
end

CreateToggle("Instant Interact (Bypass)", false, function(enabled)
    InstantEnabled = enabled
    if enabled then
        for _, v in pairs(workspace:GetDescendants()) do
            HackProximity(v)
        end
        ProximityConnection = workspace.DescendantAdded:Connect(function(v)
            if InstantEnabled then
                HackProximity(v)
            end
        end)
    else
        if ProximityConnection then
            ProximityConnection:Disconnect()
        end
    end
end)

