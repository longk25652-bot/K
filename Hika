-- ==================== MEDICINE BYPASS (LẤY THUỐC TỪ XA) ====================

CreateSectionTitle("MEDICINE BYPASS")

local function TakeMedicine(itemName)
    local found = false
    -- Cách 1: Tự động nhấn nút ProximityPrompt từ xa
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local parentName = string.lower(obj.Parent.Name)
            local promptAction = string.lower(obj.ActionText)
            local promptObject = string.lower(obj.ObjectText)
            if string.find(parentName, itemName) or string.find(promptAction, itemName) or string.find(promptObject, itemName) then
                fireproximityprompt(obj)
                found = true
            end
        end
    end
    -- Cách 2 (Dự phòng): Copy vật phẩm trực tiếp nếu tủ bị chặn
    if not found then
        for _, obj in pairs(game:GetDescendants()) do
            if obj:IsA("Tool") and string.find(string.lower(obj.Name), itemName) then
                local clone = obj:Clone()
                clone.Parent = LocalPlayer:WaitForChild("Backpack")
                found = true
                break
            end
        end
    end
end

CreateActionButton("Get Pill", function() TakeMedicine("pill") end)
CreateActionButton("Get Liquid", function() TakeMedicine("liquid") or TakeMedicine("bottle") end)
CreateActionButton("Get Vaccine", function() TakeMedicine("vaccine") or TakeMedicine("syringe") end)
CreateActionButton("Get Bandage", function() TakeMedicine("bandage") end)
CreateActionButton("Get Spray", function() TakeMedicine("spray") end)
