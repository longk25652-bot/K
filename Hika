-- ==================== MEDICINE BYPASS ====================

local function TakeMedicine(keyword)
    local found = false
    -- 1. Tìm qua ProximityPrompt
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            if string.find(string.lower(obj.Parent.Name), keyword) or string.find(string.lower(obj.ActionText), keyword) or string.find(string.lower(obj.ObjectText), keyword) then
                fireproximityprompt(obj)
                found = true
            end
        end
    end
    -- 2. Tìm qua Tool
    if not found then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") and string.find(string.lower(obj.Name), keyword) then
                LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):EquipTool(obj)
                found = true
            end
        end
    end
end

CreateActionButton("Get Pill", function() TakeMedicine("pill") end)
