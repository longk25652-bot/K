-- 1. ESP PHÂN BIỆT TỐT/XẤU (HOẠT ĐỘNG LIÊN TỤC)
local ESPEnabled = false
local function IsBadEntity(char)
    local name = string.lower(char.Name)
    local badKeywords = {"fake", "impostor", "bad", "infected", "monster", "thief", "killer", "enemy", "evil", "alien"}
    for _, v in pairs(badKeywords) do if string.find(name, v) then return true end end
    
    local attrs = char:GetAttributes()
    for attrName, value in pairs(attrs) do
        local lowerAttr = string.lower(attrName)
        if string.find(lowerAttr, "role") or string.find(lowerAttr, "team") or string.find(lowerAttr, "impostor") or string.find(lowerAttr, "bad") then
            if type(value) == "string" then
                local lowerVal = string.lower(value)
                if string.find(lowerVal, "impostor") or string.find(lowerVal, "bad") or string.find(lowerVal, "fake") or string.find(lowerVal, "infected") or string.find(lowerVal, "alien") then return true end
            elseif type(value) == "boolean" and value == true then
                if string.find(lowerAttr, "impostor") or string.find(lowerAttr, "bad") or string.find(lowerAttr, "infected") or string.find(lowerAttr, "fake") then return true end
            end
        end
    end
    
    for _, child in pairs(char:GetChildren()) do
        local childName = string.lower(child.Name)
        if string.find(childName, "impostor") or string.find(childName, "bad") or string.find(childName, "infected") or string.find(childName, "fake") or string.find(childName, "role") then
            if child:IsA("ValueBase") then
                local val = tostring(child.Value):lower()
                if string.find(val, "impostor") or string.find(val, "bad") or string.find(val, "fake") or string.find(val, "infected") then return true end
            else return true end
        end
    end
    return false
end

RunService.Heartbeat:Connect(function()
    if ESPEnabled then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= LocalPlayer.Character then
                local highlight = v:FindFirstChild("HikasESP")
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "HikasESP"
                    highlight.FillTransparency = 0.5
                    highlight.Parent = v
                end
                highlight.FillColor = IsBadEntity(v) and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
            end
        end
    else
        for _, v in pairs(Workspace:GetDescendants()) do 
            if v.Name == "HikasESP" then v:Destroy() end 
        end
    end
end)
CreateToggle("ESP Good/Bad", function(s) ESPEnabled = s end)

