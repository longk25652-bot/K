local CycleStates = { Reception = 1, DNA = 1 }
local function TeleportToArea(keywords, cycleKey)
    local targets = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Model") then
            if not v:IsDescendantOf(LocalPlayer.Character) and v.Name ~= "Baseplate" and v.Name ~= "Terrain" then
                for _, kw in ipairs(keywords) do
                    if string.find(v.Name:lower(), kw:lower()) then
                        local part = v:IsA("Model") and (v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")) or v
                        if part then
                            local isDup = false
                            for _, t in ipairs(targets) do if (t.Position - part.Position).Magnitude < 10 then isDup = true; break end end
                            if not isDup then table.insert(targets, part) end
                        end
                    end
                end
            end
        end
    end
    
    if #targets > 0 then
        local index = CycleStates[cycleKey] or 1
        if index > #targets then index = 1 end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            hrp.Velocity = Vector3.new(0,0,0)
            hrp.CFrame = targets[index].CFrame + Vector3.new(0, 5, 0)
            CycleStates[cycleKey] = (index % #targets) + 1
        end
    end
end

