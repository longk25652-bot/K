-- Tìm bệnh nhân được giao cho người chơi
local function getMyPatient()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and (v:FindFirstChild("Humanoid") or v.Name:lower():find("patient") or v.Name:lower():find("npc") or v.Name:lower():find("animal") or v.Name:lower():find("pet")) then
            local isMine = false
            if v.Name:lower():find(LocalPlayer.Name:lower()) then
                isMine = true
            elseif v:FindFirstChild("Owner") and v.Owner.Value == LocalPlayer then
                isMine = true
            elseif v:GetAttribute("Owner") == LocalPlayer.UserId or v:GetAttribute("Owner") == LocalPlayer.Name then
                isMine = true
            end
            if isMine then return v end
        end
    end
    return nil
end

-- Kích hoạt Prompt từ xa một cách thông minh (Tự động bypass khoảng cách)
local function remoteTrigger(prompt)
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        -- Cách dự phòng mượt nếu Executor của bạn không có fireproximityprompt
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp and prompt.Parent:IsA("BasePart") then
            local oldCFrame = hrp.CFrame
            hrp.CFrame = prompt.Parent.CFrame
            task.wait(0.1)
            prompt:InputHoldBegin()
            task.wait(0.1)
            prompt:InputHoldEnd()
            hrp.CFrame = oldCFrame
        end
    end
end

