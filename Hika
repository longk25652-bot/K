-- HÀM HỖ TRỢ
local function CreateTitle(text)
    local lbl = Instance.new("TextLabel", ScrollFrame); lbl.Size = UDim2.new(1, 0, 0, 25); lbl.BackgroundTransparency = 1; lbl.Text = "  " .. text; lbl.TextColor3 = Color3.fromRGB(0, 170, 255); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 13; lbl.TextXAlignment = Enum.TextXAlignment.Left
end

local function CreateBtn(name, keyword)
    local Btn = Instance.new("TextButton", ScrollFrame); Btn.Size = UDim2.new(1, -10, 0, 35); Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50); Btn.Text = "Lấy: " .. name; Btn.TextColor3 = Color3.new(1,1,1); Btn.Font = Enum.Font.Gotham; Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    Btn.MouseButton1Click:Connect(function()
        Btn.Text = "Đang lấy..."
        local found = false
        for _, prompt in pairs(workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                local pName = prompt.Parent and prompt.Parent.Name:lower() or ""
                local aText = prompt.ActionText:lower()
                if pName:find(keyword:lower()) or aText:find(keyword:lower()) then
                    if fireproximityprompt then fireproximityprompt(prompt) end
                    found = true; break
                end
            end
        end
        Btn.Text = found and "✅ Xong!" or "❌ Không thấy"
        task.wait(1); Btn.Text = "Lấy: " .. name
    end)
end

