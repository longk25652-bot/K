local ReceptionCycle = { index = 1 }
local DNACycle = { index = 1 }

local function TeleportToArea(keywords, cycleState)
    local targets = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Model") then
            if not v:IsDescendantOf(LocalPlayer.Character) and v.Name ~= "Baseplate" and v.Name ~= "Terrain" then
                for _, keyword in ipairs(keywords) do
                    if string.find(v.Name:lower(), keyword:lower()) then
                        local part = v:IsA("Model") and (v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")) or v
                        if part then
                            local isDuplicate = false
                            for _, t in ipairs(targets) do
                                if (t.Position - part.Position).Magnitude < 10 then isDuplicate = true; break end
                            end
                            if not isDuplicate then table.insert(targets, part) end
                        end
                    end
                end
            end
        end
    end
    
    if #targets > 0 then
        local index = cycleState.index or 1
        if index > #targets then index = 1 end
        local target = targets[index]
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.CFrame = target.CFrame + Vector3.new(0, 5, 0)
            cycleState.index = (index % #targets) + 1
        end
    end
end

