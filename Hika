-- TÍNH NĂNG 1: Fast Interact NPC (Đè nói chuyện mất đúng 1 giây)
local FastNPC_Connection
local function SetNPC_Duration()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            v.HoldDuration = 1 -- Đưa thời gian giữ về đúng 1 giây
        end
    end
end

CreateToggle("Fast NPC Talk (1s)", false, function(enabled)
    if enabled then
        SetNPC_Duration()
        -- Tự động áp dụng cho các NPC mới được tạo ra sau đó
        FastNPC_Connection = workspace.DescendantAdded:Connect(function(v)
            if v:IsA("ProximityPrompt") then
                v.HoldDuration = 1
            end
        end)
    else
        if FastNPC_Connection then
            FastNPC_Connection:Disconnect()
        end
    end
end)

-- TÍNH NĂNG 2: Tăng tốc độ di chuyển (WalkSpeed) lên 32
CreateToggle("Speed Hack (Fast Run)", false, function(enabled)
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = enabled and 32 or 16
    end
end)

-- TÍNH NĂNG 3: Nhảy cao hơn (JumpPower)
CreateToggle("Super Jump (Nhảy Cao)", false, function(enabled)
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
