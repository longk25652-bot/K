-- HÀM THIẾT KẾ NÚT LẤY THUỐC TỪ XA (KHÔNG CẦN NHẬP TÊN)
local function CreateFetchButton(displayName, keyword)
    local Btn = Instance.new("TextButton", ScrollFrame)
    Btn.Size = UDim2.new(1, -10, 0, 38)
    Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Btn.Text = "💊 Lấy: " .. displayName
    Btn.TextColor3 = Color3.fromRGB(230, 230, 230)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 11
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    local Stroke = Instance.new("UIStroke", Btn)
    Stroke.Color = Color3.fromRGB(45, 45, 50)
    Stroke.Thickness = 1

    Btn.MouseButton1Click:Connect(function()
        Btn.Text = "⏳ Đang quét lấy..."
        Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        
        local found = false
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        for _, prompt in pairs(workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                local pName = prompt.Parent and prompt.Parent.Name:lower() or ""
                local aText = prompt.ActionText:lower()
                local oText = prompt.ObjectText:lower()
                
                -- Đối chiếu từ khóa thông minh không phân biệt hoa thường
                if pName:find(keyword:lower()) or aText:find(keyword:lower()) or oText:find(keyword:lower()) then
                    if fireproximityprompt then
                        fireproximityprompt(prompt)
                    elseif hrp and prompt.Parent:IsA("BasePart") then
                        -- Dự phòng cho executor yếu
                        local oldCFrame = hrp.CFrame
                        hrp.CFrame = prompt.Parent.CFrame
                        task.wait(0.12)
                        prompt:InputHoldBegin()
                        task.wait(0.12)
                        prompt:InputHoldEnd()
                        hrp.CFrame = oldCFrame
                    end
                    found = true
                    break
                end
            end
        end
        
        if found then
            Btn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
            Btn.Text = "✅ Đã lấy thành công!"
        else
            Btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            Btn.Text = "❌ Không tìm thấy!"
        end
        
        task.wait(1.2)
        Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
        Btn.Text = "💊 Lấy: " .. displayName
    end)
end

